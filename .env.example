# SMA-OS Environment Configuration
# Copy this file to .env and fill in the values

# PostgreSQL Configuration
POSTGRES_USER=sma
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=sma_state

# ClickHouse Configuration
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_secure_clickhouse_password_here

# Redis Configuration (if needed)
# REDIS_URL=redis://localhost:6379

# DeepSeek API (for memory-bus ingestion)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Database URLs (for services)
DATABASE_URL=postgresql://sma:your_secure_postgres_password_here@localhost:5432/sma_state
